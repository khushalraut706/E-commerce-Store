# Copy this file to .env and fill in your own values

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local:      mongodb://127.0.0.1:27017/ecommerce_store
# Atlas:      mongodb+srv://<user>:<password>@cluster0.mongodb.net/ecommerce_store
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce_store

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Admin seed account (created/used by seed script)
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@store.com
ADMIN_PASSWORD=Admin@12345
